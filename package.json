{
  "name": "@dsaenztagarro/mcp-kit",
  "version": "0.30.1",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "description": "Batteries-included MCP framework. Define models, get CRUD tools, prompt strategies, interactive apps, OAuth, and docs — the Rails of MCP servers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./prompts": {
      "types": "./dist/prompts.d.ts",
      "import": "./dist/prompts.js"
    },
    "./apps": {
      "types": "./dist/apps.d.ts",
      "import": "./dist/apps.js"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js"
    },
    "./domain": {
      "types": "./dist/domain.d.ts",
      "import": "./dist/domain.js"
    },
    "./oauth2": {
      "types": "./dist/oauth2.d.ts",
      "import": "./dist/oauth2.js"
    },
    "./services": {
      "types": "./dist/services.d.ts",
      "import": "./dist/services.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "import": "./dist/db.js"
    },
    "./db/migrations": {
      "types": "./dist/db/migrations.d.ts",
      "import": "./dist/db/migrations.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./lib/*": "./dist/*"
  },
  "imports": {
    "#src/*": "./dist/*"
  },
  "files": [
    "dist/",
    "src/mcp/apps/shared/",
    "vendor/",
    "docs/",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc && mkdir -p dist/mcp/apps/dist && cp src/mcp/apps/dist/*.html dist/mcp/apps/dist/",
    "build:check": "tsc --noEmit",
    "build:apps": "vite build -c src/mcp/apps/vite.config.js",
    "build:all-apps": "BUILD_TARGET=model-form npm run build:apps && SKIP_CLEAN=1 BUILD_TARGET=list-view npm run build:apps && SKIP_CLEAN=1 BUILD_TARGET=record-detail npm run build:apps && SKIP_CLEAN=1 BUILD_TARGET=search-view npm run build:apps && SKIP_CLEAN=1 BUILD_TARGET=autocomplete-picker npm run build:apps && SKIP_CLEAN=1 BUILD_TARGET=multi-select npm run build:apps",
    "build:full": "npm run build:all-apps && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build:full",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.6.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "framework",
    "data",
    "oauth2",
    "tools",
    "prompts",
    "apps",
    "llm",
    "ai",
    "claude",
    "mcp-server",
    "model-driven",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsaenztagarro/mcp-kit.git"
  },
  "homepage": "https://github.com/dsaenztagarro/mcp-kit#readme",
  "bugs": {
    "url": "https://github.com/dsaenztagarro/mcp-kit/issues"
  },
  "author": "David Saenz",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@langfuse/otel": "^4.0.0",
    "@langfuse/tracing": "^4.0.0",
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@sentry/node": "^10.36.0",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "open": "^11.0.0",
    "openid-client": "^6.8.1",
    "pg": "^8.18.0",
    "sharp": "file:./vendor/sharp-noop",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@vitest/coverage-v8": "^4.0.17",
    "ajv": "^8.18.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "fast-check": "^4.6.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.7.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.32.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.0.17"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
